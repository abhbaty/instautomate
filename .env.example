# ============================================================
# Environment variables — copy this file to .env and fill in
# your real values.  NEVER commit the actual .env to git.
# ============================================================

# ------------------------------------------------------------------
# Instagram / Meta Credentials
# ------------------------------------------------------------------

# Long-lived User Access Token from Meta Graph API Explorer
# (valid for 60 days — see README for refresh instructions)
INSTAGRAM_ACCESS_TOKEN=

# The numeric Instagram Business Account ID
# Find it: GET /me/accounts → look for instagram_business_account.id
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Your Meta Developer App Secret
# Available at: developers.facebook.com → Your App → Settings → Basic
FACEBOOK_APP_SECRET=

# ------------------------------------------------------------------
# Webhook
# ------------------------------------------------------------------

# A random secret string you choose yourself.
# This MUST match what you enter in the Meta webhook settings panel.
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token_change_me

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

# SQLite (default, file-based — great for development)
DATABASE_URL=sqlite:///./app.db

# PostgreSQL example (uncomment when deploying to Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------

# Port to bind to (Railway sets this automatically)
PORT=8000
